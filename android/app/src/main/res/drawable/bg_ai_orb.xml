<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 外层发光 -->
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/typeink_accent_glow" />
            <size android:width="72dp" android:height="72dp" />
        </shape>
    </item>
    <!-- 中层阴影 -->
    <item android:left="4dp" android:top="4dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="50%"
                android:centerX="0.3"
                android:centerY="0.3"
                android:startColor="#40FFFFFF"
                android:endColor="@color/typeink_button_surface" />
            <size android:width="64dp" android:height="64dp" />
        </shape>
    </item>
    <!-- 内层球体 -->
    <item android:left="8dp" android:top="8dp" android:right="8dp" android:bottom="8dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="60%"
                android:centerX="0.35"
                android:centerY="0.35"
                android:startColor="#E6FFFFFF"
                android:centerColor="#B3FFFFFF"
                android:endColor="#80FFFFFF" />
            <size android:width="56dp" android:height="56dp" />
        </shape>
    </item>
    <!-- 高光点 -->
    <item android:left="16dp" android:top="16dp" android:right="32dp" android:bottom="32dp">
        <shape android:shape="oval">
            <solid android:color="#80FFFFFF" />
        </shape>
    </item>
</layer-list>
