<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 按下状态 -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/typeink_chip_active" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="@color/typeink_accent_end" />
        </shape>
    </item>
    <!-- 默认状态 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/typeink_key_surface" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="@color/typeink_border_soft" />
        </shape>
    </item>
</selector>
