<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 外层红色发光 -->
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/typeink_recording_glow" />
            <size android:width="72dp" android:height="72dp" />
        </shape>
    </item>
    <!-- 脉冲环 -->
    <item android:left="-4dp" android:top="-4dp" android:right="-4dp" android:bottom="-4dp">
        <shape android:shape="oval">
            <stroke android:width="2dp" android:color="@color/typeink_recording" />
        </shape>
    </item>
    <!-- 中层阴影 -->
    <item android:left="4dp" android:top="4dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="50%"
                android:centerX="0.3"
                android:centerY="0.3"
                android:startColor="#66FF4757"
                android:endColor="#CCFF4757" />
            <size android:width="64dp" android:height="64dp" />
        </shape>
    </item>
    <!-- 内层球体 -->
    <item android:left="8dp" android:top="8dp" android:right="8dp" android:bottom="8dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="60%"
                android:centerX="0.35"
                android:centerY="0.35"
                android:startColor="#FFFF6B7A"
                android:centerColor="#FFFF4757"
                android:endColor="#CCFF4757" />
            <size android:width="56dp" android:height="56dp" />
        </shape>
    </item>
</layer-list>
