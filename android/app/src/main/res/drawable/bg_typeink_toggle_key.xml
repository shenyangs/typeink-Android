<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="@color/typeink_accent_end"
                android:startColor="@color/typeink_accent_start" />
            <corners android:radius="18dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/typeink_key_surface_soft" />
            <corners android:radius="18dp" />
            <stroke
                android:width="1dp"
                android:color="@color/typeink_border" />
        </shape>
    </item>
</selector>
