<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_typeink_result_card"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="关于 Typeink"
            android:textColor="@color/typeink_text"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/aboutVersionText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="AI 语音输入法"
            android:textColor="@color/typeink_muted"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="开发者：沈旸"
            android:textColor="@color/typeink_text_secondary"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="语音输入"
            android:textColor="@color/typeink_text"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="4dp"
            android:text="1. 点中间主键开始说话。\n2. 说完自动识别并整理。\n3. 点击发送正式上屏，或继续说下一句。"
            android:textColor="@color/typeink_text_secondary"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="修改与快捷键"
            android:textColor="@color/typeink_text"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="4dp"
            android:text="可直接使用退格、空格、换行，不必每次切全键盘。需要精修时点击“修改”，对最近一句做改写。"
            android:textColor="@color/typeink_text_secondary"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="扩展与接入"
            android:textColor="@color/typeink_text"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="4dp"
            android:text="内置 DashScope 保底，也支持自定义 ASR / LLM / SyncClipboard 配置。"
            android:textColor="@color/typeink_text_secondary"
            android:textSize="14sp" />
    </LinearLayout>
</ScrollView>
