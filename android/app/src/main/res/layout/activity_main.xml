<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/typeink_screen_background"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingTop="18dp"
    android:paddingEnd="18dp"
    android:paddingBottom="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="@color/typeink_text"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/backend_hint"
                android:textColor="@color/typeink_muted"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/backendStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_typeink_status_badge"
                android:paddingStart="12dp"
                android:paddingTop="8dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp"
                android:text="@string/backend_ready"
                android:textColor="@color/typeink_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/settingsButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_settings"
                android:scaleType="centerInside"
                android:contentDescription="设置" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_typeink_panel"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="语音引擎"
                    android:textColor="@color/typeink_muted_soft"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <com.typeink.prototype.AudioWaveView
                    android:id="@+id/statusWave"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_typeink_wave_shell"
                    android:padding="10dp" />

                <TextView
                    android:id="@+id/statusSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:textColor="@color/typeink_text"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/statusHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/typeink_text_secondary"
                    android:textSize="13sp"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_typeink_segment_track"
                android:orientation="horizontal"
                android:padding="6dp">

                <TextView
                    android:id="@+id/styleNatural"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_typeink_segment_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/style_natural"
                    android:textColor="@color/typeink_muted"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/styleFormal"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_typeink_segment_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/style_formal"
                    android:textColor="@color/typeink_muted"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_typeink_panel_soft"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/editor_label"
                    android:textColor="@color/typeink_muted_soft"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/editorInput"
                    android:layout_width="match_parent"
                    android:layout_height="170dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_typeink_editor"
                    android:gravity="top|start"
                    android:hint="@string/editor_hint"
                    android:inputType="textMultiLine|textCapSentences"
                    android:padding="16dp"
                    android:textColor="@color/typeink_text"
                    android:textColorHint="@color/typeink_muted"
                    android:textSize="16sp"
                    android:lineSpacingExtra="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/operation_hint"
                    android:textColor="@color/typeink_muted"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_typeink_result_card"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/asr_label"
                        android:textColor="@color/typeink_muted_soft"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/asrText"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="10dp"
                        android:gravity="top|start"
                        android:textColor="@color/typeink_text_secondary"
                        android:textSize="14sp"
                        android:lineSpacingExtra="3dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_typeink_result_card"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/llm_label"
                        android:textColor="@color/typeink_muted_soft"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/llmText"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="10dp"
                        android:gravity="top|start"
                        android:textColor="@color/typeink_text"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:lineSpacingExtra="3dp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_typeink_panel_soft"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/ime_setup_title"
                    android:textColor="@color/typeink_text"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/imeSetupStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/typeink_text_secondary"
                    android:textSize="12sp"
                    android:lineSpacingExtra="2dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/enableImeButton"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_typeink_secondary_pill"
                        android:text="@string/ime_enable"
                        android:textAllCaps="false"
                        android:textColor="@color/typeink_text"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/switchImeButton"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_typeink_secondary_pill"
                        android:text="@string/ime_switch"
                        android:textAllCaps="false"
                        android:textColor="@color/typeink_text"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/requestMicButton"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_typeink_secondary_pill"
                        android:text="@string/ime_request_mic"
                        android:textAllCaps="false"
                        android:textColor="@color/typeink_text"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/ime_tip"
                    android:textColor="@color/typeink_muted"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/clearButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="0.8"
            android:background="@drawable/bg_typeink_secondary_pill"
            android:src="@drawable/ic_clear"
            android:scaleType="centerInside"
            android:contentDescription="清空" />

        <ImageButton
            android:id="@+id/micButton"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_weight="1.5"
            android:background="@drawable/bg_typeink_mic_button"
            android:src="@drawable/ic_mic_start"
            android:scaleType="centerInside"
            android:contentDescription="录音" />

        <ImageButton
            android:id="@+id/secondaryActionButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="0.8"
            android:background="@drawable/bg_typeink_toggle_key"
            android:src="@drawable/ic_edit"
            android:scaleType="centerInside"
            android:contentDescription="修正" />
    </LinearLayout>
</LinearLayout>
