<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_typeink_result_card"
    android:orientation="horizontal"
    android:padding="18dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/providerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/typeink_text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/providerStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_typeink_status_badge"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:textColor="@color/typeink_text_secondary"
            android:textSize="12sp" />

    </LinearLayout>

    <RadioButton
        android:id="@+id/providerRadio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:clickable="false" />

    <Button
        android:id="@+id/configButton"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_marginStart="10dp"
        android:background="@drawable/bg_typeink_secondary_pill"
        android:text="配置"
        android:textAllCaps="false"
        android:textColor="@color/typeink_text_secondary"
        android:textSize="13sp" />

</LinearLayout>
