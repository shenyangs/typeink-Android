<?xml version="1.0" encoding="utf-8"?>
<!--
    符号面板 - 内嵌在键盘区域，不是弹出窗口
    设计原则：
    1. 不遮挡主界面
    2. 有明确的返回按钮
    3. 包含常用功能键（退格）
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/symbolsPanel"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/typeink_keyboard_background"
    android:orientation="vertical"
    android:padding="6dp"
    android:visibility="gone">

    <!-- 第一行：常用标点 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/symbolComma"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_typeink_key"
            android:gravity="center"
            android:text="，"
            android:textColor="@color/typeink_text"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/symbolPeriod"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_typeink_key"
            android:gravity="center"
            android:text="。"
            android:textColor="@color/typeink_text"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/symbolQuestion"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_typeink_key"
            android:gravity="center"
            android:text="？"
            android:textColor="@color/typeink_text"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/symbolExclaim"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_typeink_key"
            android:gravity="center"
            android:text="！"
            android:textColor="@color/typeink_text"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/symbolPause"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_typeink_key"
            android:gravity="center"
            android:text="、"
            android:textColor="@color/typeink_text"
            android:textSize="18sp" />
    </LinearLayout>

    <!-- 第二行：更多标点 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/symbolColon"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_typeink_key"
            android:gravity="center"
            android:text="："
            android:textColor="@color/typeink_text"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/symbolSemicolon"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_typeink_key"
            android:gravity="center"
            android:text="；"
            android:textColor="@color/typeink_text"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/symbolQuote"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_typeink_key"
            android:gravity="center"
            android:text='"'
            android:textColor="@color/typeink_text"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/symbolApostrophe"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_typeink_key"
            android:gravity="center"
            android:text="'"
            android:textColor="@color/typeink_text"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/symbolDot"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_typeink_key"
            android:gravity="center"
            android:text="·"
            android:textColor="@color/typeink_text"
            android:textSize="18sp" />
    </LinearLayout>

    <!-- 第三行：括号 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/symbolParenL"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_typeink_key"
            android:gravity="center"
            android:text="（"
            android:textColor="@color/typeink_text"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/symbolParenR"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_typeink_key"
            android:gravity="center"
            android:text="）"
            android:textColor="@color/typeink_text"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/symbolBracketL"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_typeink_key"
            android:gravity="center"
            android:text="【"
            android:textColor="@color/typeink_text"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/symbolBracketR"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_typeink_key"
            android:gravity="center"
            android:text="】"
            android:textColor="@color/typeink_text"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/symbolBookL"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_typeink_key"
            android:gravity="center"
            android:text="《"
            android:textColor="@color/typeink_text"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/symbolBookR"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_typeink_key"
            android:gravity="center"
            android:text="》"
            android:textColor="@color/typeink_text"
            android:textSize="18sp" />
    </LinearLayout>

    <!-- 第四行：返回、退格 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/symbolBackToMain"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="2"
            android:background="@drawable/bg_typeink_key"
            android:gravity="center"
            android:text="返回"
            android:textColor="@color/typeink_text"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/symbolBackspace"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="4dp"
            android:layout_weight="2"
            android:background="@drawable/bg_typeink_key"
            android:gravity="center"
            android:text="退格"
            android:textColor="@color/typeink_text"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
