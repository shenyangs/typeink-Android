<?xml version="1.0" encoding="utf-8"?>
<!--
    参考 HeliBoard 设计 - 带工具栏的键盘布局
    顶部工具栏 + Android 原生 KeyboardView
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="336dp"
    android:layout_gravity="bottom"
    android:orientation="vertical"
    android:background="#101318">

    <!-- 顶部工具栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="#171B21">

        <!-- 返回语音按钮 -->
        <ImageView
            android:id="@+id/btnBackToVoice"
            android:layout_width="44dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_typeink_key"
            android:contentDescription="切回语音输入"
            android:padding="10dp"
            android:src="@drawable/ic_typeink_mic"
            android:tint="@color/typeink_text_primary" />

        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

        <!-- 设置/更多按钮 -->
        <ImageView
            android:id="@+id/btnSettings"
            android:layout_width="44dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_typeink_key"
            android:contentDescription="打开设置中心"
            android:padding="10dp"
            android:src="@drawable/ic_settings"
            android:tint="@color/typeink_text_secondary" />

        <View android:layout_width="8dp" android:layout_height="1dp" />

        <!-- 隐藏键盘按钮 -->
        <ImageView
            android:id="@+id/btnHideKeyboard"
            android:layout_width="44dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_typeink_key"
            android:contentDescription="收起输入法"
            android:padding="10dp"
            android:src="@drawable/ic_keyboard_hide_thin"
            android:tint="@color/typeink_text_secondary" />
    </LinearLayout>

    <!-- 键盘主体 -->
    <android.inputmethodservice.KeyboardView
        android:id="@+id/keyboardView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#101318"
        android:keyBackground="@drawable/bg_key_modern"
        android:keyTextColor="#FFFFFF"
        android:keyTextSize="18sp"
        android:labelTextSize="13sp"
        android:keyPreviewLayout="@null"
        android:keyPreviewOffset="0dp"
        android:shadowColor="#000000"
        android:shadowRadius="2"
        android:verticalCorrection="0dp" />

</LinearLayout>
