<?xml version="1.0" encoding="utf-8"?>
<FrameLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="336dp"
    android:background="#101318">

    <!-- 键盘主体 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:gravity="center">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/englishModeLabel"
                android:layout_width="68dp"
                android:layout_height="34dp"
                android:gravity="center"
                android:text="英文"
                android:textColor="@color/typeink_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/bg_typeink_primary_pill" />

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

            <TextView
                android:id="@+id/switchToVoiceBtnTop"
                android:layout_width="56dp"
                android:layout_height="34dp"
                android:gravity="center"
                android:text="语音"
                android:textColor="@color/typeink_text_secondary"
                android:textSize="12sp"
                android:background="@drawable/bg_typeink_key" />
        </LinearLayout>

        <!-- 第一行: Q W E R T Y U I O P -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center">
            
            <TextView android:id="@+id/key_q" style="@style/KeyStyle" android:text="q"/>
            <TextView android:id="@+id/key_w" style="@style/KeyStyle" android:text="w"/>
            <TextView android:id="@+id/key_e" style="@style/KeyStyle" android:text="e"/>
            <TextView android:id="@+id/key_r" style="@style/KeyStyle" android:text="r"/>
            <TextView android:id="@+id/key_t" style="@style/KeyStyle" android:text="t"/>
            <TextView android:id="@+id/key_y" style="@style/KeyStyle" android:text="y"/>
            <TextView android:id="@+id/key_u" style="@style/KeyStyle" android:text="u"/>
            <TextView android:id="@+id/key_i" style="@style/KeyStyle" android:text="i"/>
            <TextView android:id="@+id/key_o" style="@style/KeyStyle" android:text="o"/>
            <TextView android:id="@+id/key_p" style="@style/KeyStyle" android:text="p"/>
        </LinearLayout>

        <!-- 第二行: A S D F G H J K L -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp">
            
            <TextView android:id="@+id/key_a" style="@style/KeyStyle" android:text="a"/>
            <TextView android:id="@+id/key_s" style="@style/KeyStyle" android:text="s"/>
            <TextView android:id="@+id/key_d" style="@style/KeyStyle" android:text="d"/>
            <TextView android:id="@+id/key_f" style="@style/KeyStyle" android:text="f"/>
            <TextView android:id="@+id/key_g" style="@style/KeyStyle" android:text="g"/>
            <TextView android:id="@+id/key_h" style="@style/KeyStyle" android:text="h"/>
            <TextView android:id="@+id/key_j" style="@style/KeyStyle" android:text="j"/>
            <TextView android:id="@+id/key_k" style="@style/KeyStyle" android:text="k"/>
            <TextView android:id="@+id/key_l" style="@style/KeyStyle" android:text="l"/>
        </LinearLayout>

        <!-- 第三行: Shift Z X C V B N M Backspace -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center">
            
            <TextView android:id="@+id/key_shift" style="@style/KeyStyleWide" android:text="⇧"/>
            <TextView android:id="@+id/key_z" style="@style/KeyStyle" android:text="z"/>
            <TextView android:id="@+id/key_x" style="@style/KeyStyle" android:text="x"/>
            <TextView android:id="@+id/key_c" style="@style/KeyStyle" android:text="c"/>
            <TextView android:id="@+id/key_v" style="@style/KeyStyle" android:text="v"/>
            <TextView android:id="@+id/key_b" style="@style/KeyStyle" android:text="b"/>
            <TextView android:id="@+id/key_n" style="@style/KeyStyle" android:text="n"/>
            <TextView android:id="@+id/key_m" style="@style/KeyStyle" android:text="m"/>
            <TextView android:id="@+id/key_backspace" style="@style/KeyStyleWide" android:text="⌫"/>
        </LinearLayout>

        <!-- 第四行: ?123  Space  Enter -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center">
            
            <TextView android:id="@+id/key_symbol" style="@style/KeyStyleWide" android:text="\?123"/>
            <TextView android:id="@+id/key_comma" style="@style/KeyStyle" android:text=","/>
            <TextView android:id="@+id/key_space" style="@style/KeyStyleSpace" android:text="space"/>
            <TextView android:id="@+id/key_period" style="@style/KeyStyle" android:text="."/>
            <TextView android:id="@+id/key_enter" style="@style/KeyStyleWide" android:text="Enter"/>
        </LinearLayout>

        <!-- 底部工具栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="10dp"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/keyboardClearBtn"
                android:layout_width="56dp"
                android:layout_height="38dp"
                android:gravity="center"
                android:text="清"
                android:textColor="@color/typeink_text_secondary"
                android:textSize="12sp"
                android:background="@drawable/bg_typeink_key" />

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

            <TextView
                android:id="@+id/switchToVoiceBtn"
                android:layout_width="60dp"
                android:layout_height="38dp"
                android:gravity="center"
                android:text="语音"
                android:textColor="@color/typeink_text_secondary"
                android:textSize="12sp"
                android:background="@drawable/bg_typeink_key" />

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

            <TextView
                android:id="@+id/keyboardHideBtn"
                android:layout_width="56dp"
                android:layout_height="38dp"
                android:gravity="center"
                android:text="↓"
                android:textColor="@color/typeink_text_secondary"
                android:textSize="18sp"
                android:background="@drawable/bg_typeink_key" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
